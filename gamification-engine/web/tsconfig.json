{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/progress": ["../progress.ts"],
      "@/lib/nodes": ["../nodes.ts"]
    }
  },
  "include": ["src", "../JourneyPanel.tsx", "../progress.ts", "../nodes.ts"]
}
