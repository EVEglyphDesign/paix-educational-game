{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/progress": ["./progress.ts"],
      "@/lib/nodes": ["./nodes.ts"]
    }
  },
  "include": ["progress.ts", "nodes.ts", "JourneyPanel.tsx"]
}
